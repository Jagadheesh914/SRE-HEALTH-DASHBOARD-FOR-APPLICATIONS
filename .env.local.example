# Azure OpenAI configuration for the SRE Agent (/api/agent).
# Copy this file to `.env.local` and fill in your values, then restart `npm run dev`.
#
# Find these in the Azure Portal under your Azure OpenAI resource:
#   - Endpoint & Keys:   "Keys and Endpoint" blade
#   - Deployment name:   "Model deployments" (the name YOU gave the deployment, not the model id)

# e.g. https://my-resource.openai.azure.com  (no trailing slash needed)
AZURE_OPENAI_ENDPOINT=

# One of the two keys from the "Keys and Endpoint" blade
AZURE_OPENAI_API_KEY=

# The deployment name you created (e.g. gpt-4o, gpt-4o-mini, my-gpt4-deploy)
AZURE_OPENAI_DEPLOYMENT=

# Optional. Defaults to 2024-10-21 if omitted.
AZURE_OPENAI_API_VERSION=2024-10-21
